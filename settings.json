{
  "git.addAICoAuthor": "off",
  "workbench.startupEditor": "none",
  "terminal.integrated.defaultProfile.windows": "Command Prompt",
  "workbench.editor.enablePreview": false,
  "update.showReleaseNotes": false,
  "javascript.suggest.autoImports": true,
  "typescript.suggest.autoImports": true,
  "javascript.updateImportsOnFileMove.enabled": "always",
  "editor.codeActionsOnSave": {
    "source.addMissingImports": "always",
  },
  "sonarlint.automaticAnalysis": false,
  "editor.semanticHighlighting.enabled": false,
  "editor.stickyScroll.enabled": false,
  "git.openRepositoryInParentFolders": "never",
  "github.copilot.enable": {
    "*": false,
    "plaintext": false,
    "markdown": false,
    "scminput": false,
    "javascript": false,
  },
  "workbench.colorTheme": "Dark Modern",
  "editor.scrollbar.verticalScrollbarSize": 15,
  "editor.scrollbar.horizontalScrollbarSize": 15,
  "workbench.colorCustomizations": {
    "scrollbarSlider.background": "#ff000055", // Macht den Balken farbig/sichtbarer
    "scrollbarSlider.hoverBackground": "#ff0000aa",
  },
  "workbench.editor.labelFormat": "short",
  "workbench.editor.wrapTabs": true,
  "[vue]": {
    "editor.defaultFormatter": "Vue.volar",
  },
  "explorer.fileNesting.patterns": {
    "*.ts": "${capture}.js",
    "*.js": "${capture}.js.map, ${capture}.min.js, ${capture}.d.ts",
    "*.jsx": "${capture}.js",
    "*.tsx": "${capture}.ts",
    "tsconfig.json": "tsconfig.*.json",
    "package.json": "package-lock.json, yarn.lock, pnpm-lock.yaml, bun.lockb, bun.lock",
    "*.sqlite": "${capture}.${extname}-*",
    "*.db": "${capture}.${extname}-*",
    "*.sqlite3": "${capture}.${extname}-*",
    "*.db3": "${capture}.${extname}-*",
    "*.sdb": "${capture}.${extname}-*",
    "*.s3db": "${capture}.${extname}-*",
  },
  "editor.acceptSuggestionOnCommitCharacter": false,
  "editor.suggest.selectionMode": "never",
  "editor.tabCompletion": "on",
  "editor.acceptSuggestionOnEnter": "off",
  "editor.suggestSelection": "recentlyUsed",
  "explorer.compactFolders": false,
  "workbench.tree.indent": 16,
  "workbench.browser.openLocalhostLinks": false,
  "terminal.integrated.profiles.windows": {
    "PowerShell": {
      "source": "PowerShell",
      "icon": "terminal-powershell",
    },
    "Command Prompt": {
      "path": "C:\\WINDOWS\\System32\\cmd.exe",
      "args": [],
    },
    "Git Bash": {
      "source": "Git Bash",
      "icon": "terminal-git-bash",
      "path": "C:\\Program Files\\Git\\bin\\bash.exe",
      "args": ["--login", "-i"],
    },
  },
  "terminal.integrated.initialHint": false,
  "workbench.iconTheme": "material-icon-theme",
  "editor.fontSize": 18,
  "editor.wordWrap": "on",
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "editor.formatOnSave": true,
  "explorer.autoCollapse": false,
  "workbench.tree.enableStickyScroll": false,
}
